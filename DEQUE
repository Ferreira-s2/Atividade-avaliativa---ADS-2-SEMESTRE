# Exemplo de uso de fila (queue)
# Serve para entender a ideia de "primeiro que entra, primeiro que sai"

from collections import deque

fila = deque()
fila.append("A")
fila.append("B")
fila.append("C")

print("Fila inicial:", list(fila))

print("Saiu:", fila.popleft())  # A
print("Fila agora:", list(fila))

print("Saiu:", fila.popleft())  # B
print("Fila agora:", list(fila))
